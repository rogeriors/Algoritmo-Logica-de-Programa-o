Algoritmo "SomaComFuncao"

Var
X, Y : inteiro

Procedimento soma(A, B : Inteiro) //vai receber os valores de X e Y (soma(X, Y))
   escreval("Recebi o valor de ",A)
   escreval("Recebi o valor de ",B)
   escreval("A soma entre os dois valores é: ",A + B)

fimprocedimento
Inicio

   X <- 5
   Y <- 3
   soma(X, Y)

Fimalgoritmo